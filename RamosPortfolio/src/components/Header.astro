---
const navLinks = [
  { label: "Projects", href: "/projects" },
  { label: "Posts",    href: "/blog" },
  { label: "About",    href: "/about" },
];

const currentPath = Astro.url.pathname;
---

<header>
  <a href="/" class="logo">Ramos</a>

  <nav>
    {navLinks.map(link => (
      <a
        href={link.href}
        class:list={["nav-link", { active: currentPath.startsWith(link.href) }]}
      >
        {link.label}
      </a>
    ))}
  </nav>
</header>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500&display=swap');

  header {
    display: flex;
    align-items: center;
    justify-content: space-between;

    padding: 0 2.5rem;
    height: 60px;

    background: #09090f;
    border-bottom: 1px solid #1e1a2e;

    position: sticky;
    top: 0;
    z-index: 100;
  }

  /* Logo */
  .logo {
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    font-size: 1rem;
    color: #ffffff;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: color 200ms ease;
  }
  .logo:hover {
    color: #a78bfa;
  }

  /* Nav */
  nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    font-family: 'Outfit', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    color: #71717a;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 200ms ease;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: #a78bfa;
    transition: width 200ms ease;
  }

  .nav-link:hover {
    color: #e4e4f0;
  }
  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link.active {
    color: #a78bfa;
  }
  .nav-link.active::after {
    width: 100%;
  }

  /* Mobile */
  @media (max-width: 520px) {
    header { padding: 0 1.25rem; }
    nav { gap: 1.25rem; }
    .nav-link { font-size: 0.82rem; }
  }
</style>